{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "main",
	"description": "Capabilities the main window receives.",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"shell:default",
		"process:default",
		"updater:default",
		{
			"identifier": "shell:allow-execute",
			"allow": [
				{
					"name": "binaries/omp-bridge",
					"sidecar": true,
					"args": true
				},
				{
					"name": "binaries/bun",
					"sidecar": true,
					"args": true
				}
			]
		}
	]
}
