{
	"type": "module",
	"name": "@oh-my-pi/desktop-bridge",
	"version": "0.1.0",
	"private": true,
	"description": "Local HTTP+WebSocket bridge that backs the oh-my-pi desktop WebUI (collab-web). Serves installer, launcher, and chat APIs on http://localhost:8787.",
	"homepage": "https://omp.sh",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/desktop-bridge"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"keywords": [
		"desktop",
		"webui",
		"bridge",
		"installer",
		"launcher"
	],
	"main": "./src/server.ts",
	"types": "./src/server.ts",
	"bin": {
		"omp-desktop-bridge": "./src/server.ts"
	},
	"scripts": {
		"dev": "bun run src/server.ts",
		"start": "bun run src/server.ts",
		"smoke": "bun run scripts/smoke.ts",
		"compile": "bun run scripts/compile.ts",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@oh-my-pi/pi-natives": "catalog:",
		"@oh-my-pi/pi-wire": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"scripts",
		"README.md"
	]
}
